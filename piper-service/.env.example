# Copy or place your Piper model files into piper-service/models/
# Required files:
#   models/en_US-libritts-high.onnx        (the model weights)
#   models/en_US-libritts-high.onnx.json    (the model config — Piper reads this automatically)
#
# The .onnx must match speakers available in the .onnx.json speaker_id_map.
# Defaults assume the 904-speaker LibriTTS high model.

# Optional env overrides (all have sensible defaults)
# PIPER_MODEL_PATH=piper-service/models/en_US-libritts-high.onnx
# PIPER_MODEL_JSON_PATH=piper-service/models/en_US-libritts-high.onnx.json
# PIPER_DEFAULT_FEMALE=60
# PIPER_DEFAULT_MALE=25
# PIPER_MAX_TEXT_LEN=5000
# PIPER_HOST=0.0.0.0
# PIPER_PORT=8000
