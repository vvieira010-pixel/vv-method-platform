# ─── TEACHER LOGIN GATE ──────────────────────────────────────────────────────
# Gates the teacher role: only this email (comma-separate for several) resolves
# to a teacher at sign-in. Everyone else is a roster student or rejected.
VITE_TEACHER_EMAIL=your-email@gmail.com

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# The project URL and anon key are HARDWIRED in src/lib/supabase-storage.js
# (the anon key is safe to expose — Row Level Security is the protection).
# These env vars are no longer read; edit supabase-storage.js to change projects.

# ─── AI KEYS (SERVER-SIDE — set these in the Vercel dashboard) ────────────────
# These are read ONLY by the serverless proxy at /api/ai.js and are NEVER shipped
# to the browser. Provide at least one. Comma- or newline-separate to supply
# multiple keys for a provider (the cascade rotates when one is rate-limited).
# IMPORTANT: do NOT use a VITE_ prefix — that would inline the key into the
# public client bundle. Use the bare names below.
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Optional model overrides (also server-side, no VITE_ prefix):
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash
# OPENROUTER_MODELS=deepseek/deepseek-chat-v3-0324:free
# GROQ_MODEL=llama-3.3-70b-versatile
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4.1-mini

# ─── PER-USER KEYS (optional fallback) ───────────────────────────────────────
# If the server proxy has no keys, the app falls back to a key entered in the
# in-app Settings page, stored in that browser's localStorage only (never
# bundled). Keys: vv:gemini_api_key, vv:groq_api_key, vv:openrouter_api_key,
# vv:anthropic_api_key, vv:openai_api_key, vv:elevenlabs_api_key.

# ─── ELEVENLABS (TTS for student listening exercises) ────────────────────────
# Currently browser-direct: set it per-browser in Settings (vv:elevenlabs_api_key).
# Without it, listening exercises fall back to the browser's built-in TTS.
# (A server proxy for TTS is not yet implemented.)
