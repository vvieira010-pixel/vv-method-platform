# ─── TEACHER LOGIN — Auth0 ───────────────────────────────────────────────────
# Teacher authenticates via Auth0 Universal Login (no password in the app).
# Create a free account at https://auth0.com → Applications → Single Page App.
# Add the site URL to "Allowed Callback URLs" and "Allowed Logout URLs".
# The domain and clientId are public by design (Auth0 SPA pattern).
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Public project URL and anon key — safe to expose (RLS is the protection).
# Already listed in netlify.toml SECRETS_SCAN_OMIT_KEYS.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── AI KEYS (browser-side) ──────────────────────────────────────────────────
# At least one of Gemini or Groq is required for Regen/diagnosis to work.
# Also listed in netlify.toml SECRETS_SCAN_OMIT_KEYS so the deploy scan passes.
# WARNING: these are inlined into the public JS bundle — anyone can read them.
# Rotate if abused. Use a Netlify Function proxy (see /api/anthropic) if you
# need to keep a key truly private.
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_GROQ_API_KEY=your-groq-api-key

# ─── AI KEYS (server-side, safe) ─────────────────────────────────────────────
# Used only by Netlify Functions — never shipped to the browser.
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=your-openai-api-key
VITE_OPENAI_API_KEY=your-openai-api-key
VITE_OPENAI_MODEL=gpt-4.1-mini

# ─── LOCAL DEV ONLY ──────────────────────────────────────────────────────────
# Uncomment to enable the demo password login in local dev without env vars.
# VITE_ALLOW_DEMO_LOGIN=true
#
# Direct Anthropic key in browser (local testing only — never set in Netlify).
# VITE_ANTHROPIC_API_KEY=your-anthropic-api-key
# VITE_ANTHROPIC_MODEL=claude-sonnet-4-6
