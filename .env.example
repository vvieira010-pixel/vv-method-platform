# Copy this to .env and set your own PIN
VITE_TEACHER_PIN=your-pin-here

# Server-side Anthropic key for Netlify Functions.
# Set this in Netlify environment variables for production.
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=your-openai-api-key
VITE_OPENAI_API_KEY=your-openai-api-key
VITE_OPENAI_MODEL=gpt-4.1-mini

# Optional local browser-only fallback for plain Vite dev.
# This exposes the key in the browser, so use it only for local testing.
# VITE_ANTHROPIC_API_KEY=your-anthropic-api-key
# VITE_ANTHROPIC_MODEL=claude-sonnet-4-5
