# ─── TEACHER LOGIN GATE ──────────────────────────────────────────────────────
# Gates the teacher role: only this email (comma-separate for several) resolves
# to a teacher at sign-in. Everyone else is a roster student or rejected.
VITE_TEACHER_EMAIL=your-email@gmail.com

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Optional overrides for the Supabase project URL and anon key.
# If set, these take priority over the hardcoded defaults in supabase-storage.js.
# The anon key is safe to expose in the browser — Row Level Security is protection.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── AI KEYS (SERVER-SIDE — set these in the Vercel dashboard) ────────────────
# These are read ONLY by the serverless proxy at /api/ai.js and are NEVER shipped
# to the browser. Provide at least one. Comma- or newline-separate to supply
# multiple keys for a provider (the cascade rotates when one is rate-limited).
# IMPORTANT: do NOT use a VITE_ prefix — that would inline the key into the
# public client bundle. Use the bare names below.
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Optional model overrides (also server-side, no VITE_ prefix):
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash
# OPENROUTER_MODELS=deepseek/deepseek-chat-v3-0324:free
# GROQ_MODEL=llama-3.3-70b-versatile
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4.1-mini

# ─── PER-USER KEYS (optional fallback) ───────────────────────────────────────
# If the server proxy has no keys, the app falls back to a key entered in the
# in-app Settings page, stored in that browser's localStorage only (never
# bundled). Keys: vv:gemini_api_key, vv:groq_api_key, vv:openrouter_api_key,
# vv:anthropic_api_key, vv:openai_api_key, vv:elevenlabs_api_key.

# ─── ELEVENLABS (TTS for student listening exercises) ────────────────────────
# Server-side key used by /api/tts. Do NOT use a VITE_ prefix.
# Without it, listening exercises fall back to OpenAI TTS, browser keys, Piper,
# or the browser's built-in TTS.
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Optional:
# Use one woman voice and one man voice for listening variety.
# ElevenLabs voice IDs come from your ElevenLabs voice library.
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_multilingual_v2

# Optional fallback after ElevenLabs, before OpenAI TTS:
DEEPGRAM_API_KEY=your-deepgram-api-key
# Deepgram Aura examples: aura-2-thalia-en, aura-2-orion-en.
# DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# Optional OpenAI TTS fallback voice. Examples: nova (woman), onyx (man), alloy (neutral).
# OPENAI_TTS_VOICE=nova

# Optional Piper offline voices:
# Use one woman voice and one man voice for listening variety.
# Piper needs both .onnx and .onnx.json files for each voice.
# Suggested English starting points from voices.json:
# US woman: en_US-lessac-medium or en_US-amy-medium
# US man: en_US-ryan-medium or en_US-hfc_male-medium
# UK woman: en_GB-southern_english_female-low
# UK man: en_GB-northern_english_male-medium

# ── Piper LOCAL (development only — default for listening dialogs) ───────────
# When set, PiperLocalProvider becomes the FIRST provider in /api/tts.js, so all
# listening dialogs use Piper's man/woman voices (LibriTTS female=60, male=25).
# Unset (=empty) in production so deployed Vercel never tries localhost.
# To batch-generate static WAV files for all dialogue-bank items:
#   node scripts/generate-listening-audio.mjs
# See piper-service/README.md for setup.
PIPER_LOCAL_URL=http://localhost:8000

# ── Calendar class invites (Zoom link emailed as .ics) ───────────────────────
# The calendar's "Send invite" button emails a student an .ics invite containing
# your Zoom link via Resend (https://resend.com). Server-side only — no VITE_ prefix.
# RESEND_API_KEY: transactional email API key.
# INVITE_FROM_EMAIL: a verified sender address on your Resend domain.
# INVITE_FROM_NAME: optional display name for the sender (default "MET Class").
RESEND_API_KEY=
INVITE_FROM_EMAIL=
INVITE_FROM_NAME=
