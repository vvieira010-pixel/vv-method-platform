# Copy this to .env and set local test credentials.
# These browser-exposed values are temporary until Supabase Auth is wired.
VITE_TEACHER_EMAIL=teacher@vvmethod.com
VITE_TEACHER_PASSWORD=change-this-local-password

# Server-side Anthropic key for Netlify Functions.
# Set this in Netlify environment variables for production.
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=your-openai-api-key
VITE_OPENAI_API_KEY=your-openai-api-key
VITE_OPENAI_MODEL=gpt-4.1-mini

# Browser-exposed AI keys (inlined into the client bundle by Vite).
# Set in Netlify env for production; these are also listed in
# netlify.toml SECRETS_SCAN_OMIT_KEYS so the deploy's secrets scan passes.
# NOTE: a VITE_ key ships in the public bundle and can be scraped.
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_GROQ_API_KEY=your-groq-api-key

# Optional local browser-only fallback for plain Vite dev.
# This exposes the key in the browser, so use it only for local testing.
# VITE_ANTHROPIC_API_KEY=your-anthropic-api-key
# VITE_ANTHROPIC_MODEL=claude-sonnet-4-6
