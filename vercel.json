{
  "installCommand": "npm ci",
  "buildCommand": "ls -la src/components/exercises/ && find src/components -name 'ExercisePlayer*' -type f && echo '---BUILD---' && npx vite build",
  "outputDirectory": "dist-build",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
    }
  ]
}
