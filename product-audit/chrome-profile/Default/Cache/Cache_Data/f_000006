: var(--text-2);\r\n  font-size: var(--text-xs);\r\n  line-height: 1.55;\r\n  flex: 1;\r\n  min-width: 180px;\r\n}\r\n.student-stage-track {\r\n  display: grid;\r\n  grid-template-columns: repeat(5, minmax(0, 1fr));\r\n  gap: 5px;\r\n}\r\n.student-stage-track span {\r\n  height: 7px;\r\n  border-radius: 999px;\r\n  background: var(--bg-deep);\r\n}\r\n.student-stage-track span.active {\r\n  background: var(--accent);\r\n}\r\n.student-stage-track--wide {\r\n  margin-bottom: 10px;\r\n}\r\n.student-readiness-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n  gap: 10px;\r\n  margin-bottom: 12px;\r\n}\r\n.student-progress-card {\r\n  background: var(--surface);\r\n  border: 1.5px solid rgba(26, 35, 50, 0.2);\r\n  border-radius: 6px;\r\n  padding: 13px;\r\n  box-shadow: none;\r\n  min-width: 0;\r\n}\r\n.student-progress-copy-grid {\r\n  display: grid;\r\n  grid-template-columns: 1fr;\r\n  gap: 8px;\r\n}\r\n.student-progress-copy-grid div {\r\n  padding: 9px;\r\n  border: 1px solid var(--divider);\r\n  border-radius: 6px;\r\n  background: #fff;\r\n}\r\n.student-progress-copy-grid strong {\r\n  display: block;\r\n  margin-bottom: 5px;\r\n  color: var(--text);\r\n  font-size: var(--text-xs);\r\n}\r\n.student-progress-copy-grid p {\r\n  margin: 0;\r\n  color: var(--text-2);\r\n  font-size: var(--text-xs);\r\n  line-height: 1.55;\r\n}\r\n.student-history-list {\r\n  display: grid;\r\n  gap: 8px;\r\n}\r\n.student-history-item {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  gap: 10px;\r\n  padding: 9px;\r\n  border: 1px solid var(--divider);\r\n  border-radius: 6px;\r\n  background: #fff;\r\n}\r\n.student-history-item strong {\r\n  display: block;\r\n  color: var(--text);\r\n  font-size: var(--text-sm);\r\n}\r\n.student-history-item p {\r\n  margin: 4px 0 0;\r\n  color: var(--text-2);\r\n  font-size: var(--text-xs);\r\n  line-height: 1.55;\r\n}\r\n.student-history-item span {\r\n  flex-shrink: 0;\r\n  color: var(--muted);\r\n  font-size: var(--text-xs);\r\n  font-weight: 700;\r\n}\r\n\r\n/* ── Top nav ── */\r\n.dash-top-nav {\r\n  flex: 1 1 auto;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 6px;\r\n  min-width: 0;\r\n}\r\n.dash-nav-btn {\r\n  min-height: 38px;\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 6px;\r\n  border: 1px solid transparent;\r\n  border-radius: 8px;\r\n  background: none;\r\n  cursor: pointer; font-family: var(--font-ui); color: var(--muted);\r\n  transition: color 0.15s, background 0.15s, border-color 0.15s;\r\n  padding: 0 10px;\r\n}\r\n.dash-nav-btn.active {\r\n  color: var(--text);\r\n  font-weight: 700;\r\n  background: var(--bg);\r\n  border-color: var(--border);\r\n}\r\n.dash-nav-icon { display: flex; }\r\n.dash-nav-label { font-size: 12px; font-weight: 700; letter-spacing: 0; }\r\n\r\n/* ── Page layout ── */\r\n.dash-page { padding: 24px 16px; max-width: 700px; margin: 0 auto; }\r\n.dash-header { margin-bottom: 20px; }\r\n.dash-greeting h1 { font-size: 24px; font-weight: 800; color: var(--text); margin: 0 0 4px; }\r\n.dash-greeting p { font-size: 13.5px; color: var(--text-2); margin: 0; line-height: 1.55; }\r\n.dash-date     { font-size: 13px; color: var(--text-2); font-weight: 500; }\r\n.dash-section-label {\r\n  font-size: 11px; font-weight: 700; text-transform: uppercase;\r\n  letter-spacing: 0.08em; color: var(--text); margin-bottom: 10px;\r\n  border-bottom: 1px solid var(--border); padding-bottom: 6px;\r\n}\r\n\r\n.dash-home-glance {\r\n  display: grid;\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n  gap: 10px;\r\n  margin: 12px 0 16px;\r\n}\r\n.dash-glance-card {\r\n  background: var(--surface);\r\n  border: 1.5px solid var(--text);\r\n  border-radius: 4px;\r\n  padding: 14px 14px;\r\n}\r\n.dash-glance-card--wide {\r\n  grid-column: 1 / -1;\r\n}\r\n.dash-glance-card strong {\r\n  display: block;\r\n  font-size: 11px;\r\n  color: var(--text);\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.06em;\r\n  margin-bottom: 6px;\r\n  font-weight: 800;\r\n}\r\n.dash-glance-card p {\r\n  font-size: 13px;\r\n  color: var(--text-2);\r\n  line-height: 1.55;\r\n  margin: 0;\r\n}\r\n\r\n/* ── Stats row ── */\r\n.dash-stats { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 18px; }\r\n.dash-stat   { flex: 1; min-width: 80px; background: var(--surface);\r\n  border: 1.5px solid var(--text); border-radius: 4px; padding: 14px 14px; }\r\n.dash-stat-value { font-size: 22px; font-weight: 800; color: var(--text); line-height: 1; }\r\n.dash-stat-label { font-size: 11px; color: var(--text-2); margin-top: 4px; font-weight: 500; }\r\n\r\n/* ── Card ── */\r\n.dash-card {\r\n  background: var(--surface); border: 1.5px solid var(--border);\r\n  border-radius: 4px; padding: 16px; margin-bottom: 12px;\r\n}\r\n.dash-card-header {\r\n  display: flex; justify-content: space-between; align-items: flex-start;\r\n  margin-bottom: 12px;\r\n}\r\n.dash-card-title { font-size: 14px; font-weight: 700; color: var(--text); }\r\n.dash-card-sub   { font-size: 12px; color: var(--text-2); margin-top: 2px; }\r\n.dash-card-meta  { font-size: 11px; color: var(--muted); }\r\n.dash-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }\r\n.dash-col-card {\r\n  background: var(--surface); border: 1.5px solid var(--border);\r\n  border-radius: 4px; padding: 14px;\r\n}\r\n.dash-col-card h3 {\r\n  font-size: 12px; font-weight: 700; text-transform: uppercase;\r\n  letter-spacing: 0.06em; color: var(--text); margin: 0 0 10px;\r\n}\r\n\r\n/* ── Gamification ── */\r\n.dash-gam-hero {\r\n  background: var(--text); border-radius: 4px; padding: 20px;\r\n  color: #fff; margin-bottom: 12px;\r\n}\r\n.dash-gam-level  { font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.5);\r\n  text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }\r\n.dash-gam-name   { font-size: 20px; font-weight: 800; margin-bottom: 12px; }\r\n.dash-gam-bar-track { height: 8px; background: rgba(255,255,255,0.15); border-radius: 2px; overflow: hidden; }\r\n.dash-gam-bar-fill  { height: 100%; background: #a8dadc; border-radius: 2px; transition: transform 0.6s; transform-origin: left; }\r\n.dash-gam-bar-labels { display: flex; justify-content: space-between; margin-top: 5px;\r\n  font-size: 11px; color: rgba(255,255,255,0.5); }\r\n.dash-gam-stat-label { font-size: 11px; color: rgba(255,255,255,0.6); }\r\n\r\n/* ── Homework items ── */\r\n.dash-hw-item {\r\n  display: flex; gap: 12px; align-items: flex-start;\r\n  padding: 12px 0; border-bottom: 1px solid var(--divider);\r\n}\r\n.dash-hw-item:last-child { border-bottom: none; }\r\n.dash-hw-num  { width: 28px; height: 28px; border-radius: 4px; background: var(--accent-soft);\r\n  color: var(--accent); font-size: 11px; font-weight: 700;\r\n  display: flex; align-items: center; justify-content: center; flex-shrink: 0; }\r\n.dash-hw-title { font-size: 13.5px; font-weight: 600; color: var(--text); margin-bottom: 3px; }\r\n.dash-hw-meta  { font-size: 11.5px; color: var(--muted); }\r\n\r\n/* ── Feedback items ── */\r\n.dash-feedback-card { border: 1.5px solid var(--border); border-radius: 4px; padding: 16px; margin-bottom: 10px; background: var(--surface); }\r\n.dash-feedback-text { font-size: 13.5px; color: var(--text-2); line-height: 1.7; }\r\n\r\n/* ── Today task list ── */\r\n.dash-tasks { display: grid; gap: 8px; }\r\n.dash-task {\r\n  display: grid; grid-template-columns: auto 1fr auto; gap: 10px; align-items: center;\r\n  border: 1.5px solid var(--border); background: var(--surface); border-radius: 4px; padding: 12px 14px;\r\n}\r\n.dash-task-check {\r\n  width: 28px; height: 28px; border-radius: 4px; background: var(--text); color: #fff;\r\n  display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700;\r\n}\r\n.dash-task-label { font-size: 13.5px; font-weight: 600; color: var(--text); }\r\n.dash-task-sub { font-size: 11.5px; color: var(--text-2); margin-top: 2px; }\r\n.dash-task-pill {\r\n  font-size: 11px; font-weight: 700; border-radius: 2px; padding: 4px 8px;\r\n  background: var(--warning-bg); color: var(--warning);\r\n}\r\n.dash-task-pill.urgent { background: var(--warning-bg); color: var(--warning); }\r\n\r\n/* ── Homework set cards ── */\r\n.dash-hw-set {\r\n  border: 1.5px solid var(--border); border-radius: 4px; padding: 16px; background: var(--surface);\r\n  margin-bottom: 10px; cursor: pointer; transition: border-color 0.15s, background 0.15s;\r\n}\r\n.dash-hw-set:hover { border-color: var(--text); background: var(--bg); }\r\n.dash-hw-set.completed { border-color: var(--success); }\r\n.dash-hw-set.in-progress { border-color: var(--warning); }\r\n.dash-hw-set-head { display: flex; justify-content: space-between; align-items: center; gap: 10px; margin-bottom: 8px; }\r\n.dash-hw-set-num { font-size: 11px; font-weight: 700; color: var(--text); text-transform: uppercase; letter-spacing: 0.06em; }\r\n.dash-hw-set-status { font-size: 11px; font-weight: 700; border-radius: 2px; padding: 3px 8px; background: var(--divider); color: var(--text-2); }\r\n.dash-hw-set-status.not-started { background: var(--divider); color: var(--text-2); }\r\n.dash-hw-set-status.in-progress { background: var(--warning-bg); color: var(--warning); }\r\n.dash-hw-set-status.completed { background: var(--success-bg); color: var(--success); }\r\n.dash-hw-set-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 4px; }\r\n.dash-hw-set-desc { font-size: 13px; color: var(--text-2); line-height: 1.6; margin-bottom: 8px; }\r\n.dash-hw-set-meta { display: flex; gap: 6px; flex-wrap: wrap; font-size: 11.5px; color: var(--text-2); }\r\n\r\n/* ── Practice wall ── */\r\n.dash-wall { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }\r\n.dash-wall-card { border: 1.5px solid var(--border); border-radius: 4px; background: var(--surface); padding: 16px; }\r\n.dash-wall-car